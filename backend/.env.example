# MongoDB Atlas connection string
# Get this from Atlas: Cluster > Connect > Drivers. Include the DB name, e.g. .../expense-tracker
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expense-tracker?retryWrites=true&w=majority

# Secret used to sign JWTs (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Port the API server listens on
PORT=8000

# URL of the frontend (used for CORS). Vite dev server default is 5173.
# REQUIRED in production — the server refuses to start without it (no open-CORS
# fallback), and it must exactly match the deployed frontend origin.
CLIENT_URL=http://localhost:5173

# Environment. Set to "production" on your host so error responses don't leak
# internal messages and CLIENT_URL is enforced. Leave unset/development locally.
NODE_ENV=development

# --- Email (password reset) ---
# OPTIONAL. If these SMTP vars are unset, password-reset emails are NOT sent —
# instead the reset link is logged to the backend console (dev fallback), so the
# flow works locally with zero setup. Set them to send real email in production.
# Example values are for Gmail (requires a Google "app password", not your login).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Personal Finance Manager <you@gmail.com>"
